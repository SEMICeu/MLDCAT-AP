	a dcat:Dataset .

<https://huggingface.co/datasets/common-pile/stackv2_edu_filtered> dct:title "stackv2_edu_filtered" ;
	dct:description "We filter the Stack V2 to only include code from openly licensed repositories, based on the license detection performed by the creators of Stack V2." ;
