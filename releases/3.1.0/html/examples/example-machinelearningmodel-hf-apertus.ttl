	a dcat:Dataset .

<https://huggingface.co/datasets/HuggingFaceTB/finemath> dct:title "finemath" ;
	dct:description "ineMath consists of 34B tokens (FineMath-3+) and 54B tokens (FineMath-3+ with InfiMM-WebMath-3+) of mathematical educational content filtered from CommonCrawl." ;
	it6:collectionDate "2025-02-06"^^xsd:date ;
	a dcat:Dataset .

<https://huggingface.co/datasets/LLM360/MegaMath> dct:title "MegaMath" ;
	dct:description "an open math pretraining dataset curated from diverse, math-focused sources, with over 300B tokens." ;
	it6:collectionDate "2025-04-09"^^xsd:date ;
	a dcat:Dataset .

<https://huggingface.co/datasets/HuggingFaceTB/smoltalk2> dct:title "smoltalk2" ;
	dct:description "This dataset contains three subsets (Mid, SFT, Preference) that correspond to the three phases of Post-Training for SmolLM3-3B." ;
	it6:collectionDate "2025-10-31"^^xsd:date ;
	a dcat:Dataset .

<https://huggingface.co/datasets/utter-project/EuroBlocks-SFT-Synthetic-1124> dct:title "EuroBlocks-SFTSynthetic-1124" ;
	dct:description "Synthethic data used to train EuroLLM 9B Instruct." ;
