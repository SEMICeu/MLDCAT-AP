<https://huggingface.co/datasets/HuggingFaceFW/fineweb-edu> dct:title "FineWeb-Edu" ;
	it6:collectionDate "2024-09-02"^^xsd:date ;
	dcat:version "1.0.0" ;
	dct:description "FineWeb-Edu dataset consists of 1.3T tokens and 5.4T tokens (FineWeb-Edu-score-2) of educational web pages filtered from 🍷 FineWeb dataset. This is the 1.3 trillion version." ;
