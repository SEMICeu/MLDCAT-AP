	a dcat:Dataset .

<https://huggingface.co/datasets/HuggingFaceTB/dclm-edu> dct:title "dclm-edu" ;
	dct:description "This is a filtered version of DCLM dataset using FineWeb-Edu educational quality classifier" ;
