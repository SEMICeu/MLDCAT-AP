	a dcat:Dataset .

<https://huggingface.co/datasets/HuggingFaceFW/fineweb-2> dct:title "fineweb-2" ;
	dct:description "This is the second iteration of the popular FineWeb dataset, bringing high quality pretraining data to over 1000 languages." ;
